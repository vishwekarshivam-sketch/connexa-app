{
  "expo": {
    "name": "Connexa",
    "slug": "connexa-iitb",
    "version": "1.0.0",
    "scheme": "connexa",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.connexa.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#15161C"
      },
      "package": "app.connexa.mobile",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "connexa.app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Connexa",
      "shortName": "Connexa",
      "description": "The social network for IIT students.",
      "lang": "en-IN",
      "themeColor": "#15161C",
      "backgroundColor": "#15161C",
      "bundler": "metro",
      "display": "standalone",
      "orientation": "portrait"
    },
    "description": "The IIT social network.",
    "extra": {
      "eas": {
        "projectId": "c97fa327-5fa6-4b74-a3db-792b14b0e808"
      }
    },
    "plugins": [
      "expo-font",
      "expo-document-picker",
      "expo-image-picker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#15161C"
        }
      ]
    ],
    "owner": "originaltbs-organization"
  }
}
